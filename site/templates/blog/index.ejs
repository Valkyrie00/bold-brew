<main class="container page-content">
    <% if (locals.breadcrumb) { %>
        <%- include('../partials/breadcrumb') %>
    <% } %>

    <header class="mb-5">
        <h1>Bold Brew Blog</h1>
        <p class="lead">Tips, tutorials, and guides for managing packages on macOS and Linux</p>
    </header>

    <div class="row">
        <div class="col-lg-8">
            <div class="blog-posts">
                <% posts.forEach(post => { %>
                    <article class="blog-post mb-5">
                        <div class="post-meta">
                            <span class="date"><%= post.date %></span>
                            <span class="author">By Valkyrie00</span>
                        </div>
                        <h2><a href="<%= post.url %>"><%= post.title %></a></h2>
                        <p class="excerpt"><%= post.excerpt %></p>
                        <% if (post.tags && post.tags.length > 0) { %>
                            <div class="tags">
                                <% post.tags.forEach(tag => { %>
                                    <a href="/blog/?tag=<%= encodeURIComponent(tag) %>" class="tag"><%= tag %></a>
                                <% }); %>
                            </div>
                        <% } %>
                        <a href="<%= post.url %>" class="read-more">Read more →</a>
                    </article>
                <% }); %>
            </div>
        </div>

        <aside class="col-lg-4">
            <div class="sidebar">
                <div class="widget mb-4">
                    <h3>About Bold Brew</h3>
                    <p>Bold Brew is a modern Terminal User Interface for managing Homebrew, Mac App Store, and Flatpak packages on macOS and Linux.</p>
                    <a href="/#install" class="btn btn-primary">Install Now</a>
                </div>

                <div class="widget mb-4">
                    <h3>Popular Tags</h3>
                    <div class="tags">
                        <a href="/blog/?tag=Homebrew" class="tag">Homebrew</a>
                        <a href="/blog/?tag=TUI" class="tag">TUI</a>
                        <a href="/blog/?tag=Security" class="tag">Security</a>
                        <a href="/blog/?tag=Brewfile" class="tag">Brewfile</a>
                        <a href="/blog/?tag=macOS" class="tag">macOS</a>
                        <a href="/blog/?tag=Linux" class="tag">Linux</a>
                        <a href="/blog/?tag=Project+Bluefin" class="tag">Project Bluefin</a>
                    </div>
                </div>

                <div class="widget mb-4">
                    <h3>Follow Us</h3>
                    <div class="social-links">
                        <a href="https://github.com/Valkyrie00/bold-brew" target="_blank" rel="noopener noreferrer">GitHub</a>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</main>
